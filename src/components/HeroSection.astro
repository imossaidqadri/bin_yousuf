---
import { projects } from '../data/projects.js';

const heroWords = projects.map(project => project.name.toUpperCase());
---

<main class="min-h-screen flex items-center justify-start relative">
  <div class="text-left relative">
    <span class="text-byg-color text-6xl md:text-7xl lg:text-8xl font-medium tracking-tight mr-2 sm:mr-4">BYG</span>
    <span id="animatedText"
          class="inline-block text-byg-color text-6xl md:text-7xl lg:text-8xl font-medium tracking-tight
                 transition-all duration-800 ease-in-out">
      PANORAMA
    </span>
    <div class="block text-sm sm:text-base font-semibold text-neutral-500 uppercase mt-1 tracking-wider sm:tracking-widest">
      Official Partners With EMAAR® Oceanfront & HMR® Waterfront
    </div>
  </div>
</main>

<script define:vars={{ heroWords }}>
  const words = heroWords;
  let currentIndex = 0;
  const animatedText = document.getElementById("animatedText");

  function changeWord() {
    if (!animatedText) return;

    // Apply blur-out and transform for the transition
    animatedText.classList.add("blur-out", "opacity-0", "translate-y-[-20px]");
    animatedText.classList.remove("blur-in", "opacity-100", "translate-y-0");

    setTimeout(() => {
      if (!animatedText) return;
      currentIndex = (currentIndex + 1) % words.length;
      animatedText.textContent = words[currentIndex];

      // Remove blur-out and apply blur-in for the next transition
      animatedText.classList.remove("blur-out", "opacity-0", "translate-y-[-20px]");
      animatedText.classList.add("blur-in", "opacity-100", "translate-y-0");
    }, 400); // Half of the animation duration
  }

  // Initial delay before starting the word change interval
  setTimeout(() => {
    setInterval(changeWord, 3000); // Change word every 3 seconds
  }, 2000); // Start after 2 seconds
</script>

<style>
  /* Define custom Tailwind classes for blur animations */
  .blur-out {
    filter: blur(10px);
  }

  .blur-in {
    filter: blur(0px);
  }

  /* Define a custom color for 'BYG' to avoid repetitive utility classes */
  .text-byg-color {
    color: #4c4c4c; /* Adjust as needed */
  }
</style>